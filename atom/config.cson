"*":
  "atom-material-ui":
    colors: {}
    tabs:
      compactTabs: true
      tintedTabBar: true
    treeView:
      compactList: true
    ui:
      panelContrast: true
  core:
    disabledPackages: [
      "language-vue-component"
      "language-pug-jade"
    ]
    telemetryConsent: "no"
    themes: [
      "atom-dark-ui"
      "oceanic-next"
    ]
  editor:
    fontFamily: "Inconsolata-g"
    fontSize: 16
    showIndentGuide: true
  "exception-reporting":
    userId: "8961735e-13dc-a715-1ea5-1b04b5597587"
  "file-icons": {}
  "tree-view":
    hideIgnoredNames: true
  "vim-mode-plus":
    clearMultipleCursorsOnEscapeInsertMode: true
    debug: true
    groupChangesWhenLeavingInsertMode: false
  welcome:
    showOnStartup: false
