## Fresh setup

# handles updating fresh
fresh freshshell/fresh bin/fresh --bin

# dircolors: colorized ls
fresh seebi/dircolors-solarized dircolors.ansi-dark --file=~/.dircolorsrc

## Config
fresh config/\* --file

## Sublime Text
fresh sublimetext --file=~/Library/Application\ Support/Sublime\ Text\ 3/Packages/User/

## Atom
fresh atom/config.cson --file=~/.atom/config.cson
fresh atom/keymap.cson --file=~/.atom/keymap.cson
fresh atom/projects.cson --file=~/.atom/projects.cson
fresh atom/styles.less --file=~/.atom/styles.less
fresh atom/snippets.cson --file=~/.atom/snippets.cson

# fish: the friendly interactive shell, for humans
fresh-options --file=~/.config/fish/config.fish --marker
    fresh fish/config.fish
    fresh fish/aliases.fish
fresh-options

# for function in ~/.dotfiles/config/fish/functions/*.fish; do
#     fresh config/fish/functions/"$(basename "$function")" --file=~/.config/fish/functions/"$(basename "$function")"
# done

# fisherman: package manager for fish
fresh fish/fishfile --file=~/.config/fish/fishfile
fresh fisherman/fisherman fisher.fish --file=~/.config/fish/functions/fisher.fish

fresh_after_build () {
    chmod +w ~/.fresh/build/config-fish-fishfile
    chmod u=rw,g+r,o+r ~/.fresh/build/atom-config.cson
    chmod u=rw,g+r,o+r ~/.fresh/build/atom-keymap.cson
    chmod u=rw,g+r,o+r ~/.fresh/build/atom-projects.cson
    chmod u=rw,g+r,o+r ~/.fresh/build/atom-styles.less
    chmod u=rw,g+r,o+r ~/.fresh/build/atom-snippets.cson
}
